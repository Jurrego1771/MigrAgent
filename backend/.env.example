# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=3001
NODE_ENV=development

# Mediastream API
MEDIASTREAM_API_URL=https://platform.mediastre.am

# MEDIASTREAM_API_TOKEN: Token JWT de Mediastream
# Para obtenerlo:
# 1. Inicia sesión en https://platform.mediastre.am
# 2. Abre las DevTools del navegador (F12)
# 3. Ve a Application > Cookies > platform.mediastre.am
# 4. Copia el valor de la cookie 'jwt'
#
# Alternativamente, en la consola del navegador ejecuta:
#   document.cookie.match(/jwt=([^;]+)/)?.[1]
#
# El token tiene formato: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx.xxxxx
MEDIASTREAM_API_TOKEN=your_jwt_token_here

# MEDIASTREAM_SESSION_COOKIE: Cookie de sesión de Mediastream (REQUERIDO)
# Las rutas de migration requieren una sesión activa. Para obtenerla:
# 1. Inicia sesión en https://platform.mediastre.am
# 2. Abre las DevTools del navegador (F12)
# 3. Ve a Application > Cookies > platform.mediastre.am
# 4. Copia el valor COMPLETO de la cookie 'connect.sid'
#
# Alternativamente, en la consola del navegador ejecuta:
#   document.cookie.match(/connect\.sid=([^;]+)/)?.[1]
#
# El valor tiene formato: s%3Axxxxxxxxxxxx.yyyyyyyyyyyy
MEDIASTREAM_SESSION_COOKIE=your_connect_sid_here

# MEDIASTREAM_ACCOUNT_ID: ID de tu cuenta en Mediastream
# Lo puedes encontrar en:
# 1. La URL cuando estás en settings: /account/{ACCOUNT_ID}/settings
# 2. O en DevTools > Application > localStorage > busca 'account' o 'accountId'
MEDIASTREAM_ACCOUNT_ID=your_account_id_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
